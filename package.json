{
  "name": "tide-canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "TideCanvas desktop workspace built with React and Electron.",
  "author": "TideCanvas",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 3000 --strictPort\" \"wait-on http://127.0.0.1:3000 && electron electron/main.cjs\"",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 3000 --strictPort",
    "electron:preview": "npm run build && electron electron/main.cjs",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win nsis",
    "dist:win:portable": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@google/genai": "^1.37.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.8.2",
    "vite": "^7.3.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.tidecanvas.app",
    "productName": "TideCanvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "!**/*.map",
      "!**/node_modules/.cache/**/*"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TideCanvas"
    }
  }
}
